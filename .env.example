# Google Drive API Configuration
# 
# Untuk menampilkan foto dari Google Drive, Anda perlu:
# 1. Buka Google Cloud Console (https://console.cloud.google.com)
# 2. Buat project baru atau pilih yang sudah ada
# 3. Enable "Google Drive API" di APIs & Services > Library
# 4. Buat API Key di APIs & Services > Credentials > Create Credentials > API Key
# 5. Copy API Key dan paste di bawah ini
#
# PENTING: Folder Google Drive harus di-share sebagai "Anyone with the link can view"

NEXT_PUBLIC_GOOGLE_API_KEY=your_google_api_key_here

# Optional: Cloudflare Worker fallback for grid thumbnails.
# Direct Google thumbnails are used first; the Worker is tried only if they fail.
NEXT_PUBLIC_CF_THUMB_WORKER_URL=https://thumb.ryanekoapp.web.id

# Cloudflare Turnstile (for register CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Telegram Bot (for auto-reminder notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Telegram Bot + Chat ID for admin signup alerts (ryaneko license alert channel)
ALERT_TELEGRAM_BOT_TOKEN=your_alert_telegram_bot_token_here
ALERT_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Cron Secret (for securing cron API endpoints)
CRON_SECRET=your_random_secret_here

# Multi-Tenant SaaS — Admin Configuration
ADMIN_API_KEY=your_random_api_key_for_license_portal
